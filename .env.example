# =============================================================================
# llm-stack — .env.example  (SAFE TO COMMIT — no real secrets)
# Copy to .env and fill in real values before starting the stack.
# =============================================================================

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
DEEPSEEK_API_KEY=REPLACE_ME_WHEN_READY

LITELLM_MASTER_KEY=sk-local-REPLACE_WITH_RANDOM_STRING
LITELLM_SALT_KEY=REPLACE_WITH_32_BYTE_HEX

LLAMA_MODEL_DIR=/data/models/gguf
LLAMA_MODEL_FILE=Qwen3-Coder-Next-UD-Q4_K_XL.gguf
LLAMA_N_GPU_LAYERS=999
LLAMA_CTX_SIZE=32768
LLAMA_PARALLEL=1
LLAMA_BATCH_SIZE=512
LLAMA_FLASH_ATTN=1

VLLM_MODEL_DIR=/data/models/hf
VLLM_MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.45
VLLM_MAX_MODEL_LEN=8192
